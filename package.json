{
  "name": "jarvis-ai-web-animation",
  "version": "0.1.1",
  "description": "Jarvis-style AI orb — React component with Three.js orbital animation, themeable palettes, and state-driven moods.",
  "license": "MIT",
  "author": "cyber1443",
  "homepage": "https://github.com/cyber1443/jarvis-ai-web-animation#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyber1443/jarvis-ai-web-animation.git"
  },
  "bugs": "https://github.com/cyber1443/jarvis-ai-web-animation/issues",
  "keywords": [
    "jarvis",
    "ai",
    "orb",
    "mascot",
    "react",
    "three.js",
    "webgl",
    "animation"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.0",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
